import java.util.Scanner;

public class conversion {

    // Convert to Decimal
    public static int toDecimal(String number, int fromBase) {
        int decimal = 0;
        for (char digit : number.toCharArray()) {
            int digitValue = Character.digit(digit, fromBase);
            decimal = decimal * fromBase + digitValue;
        }
        return decimal;
    }
    
    // Convert from Decimal to another base
    public static String fromDecimal(int decimal, int toBase) {
        if (decimal == 0) return "0";
        
        String result = "";
        while (decimal > 0) {
            int remainder = decimal % toBase;
            if (remainder < 10) {
                result = remainder + result;
            } else {
                result = (char)('A' + remainder - 10) + result;
            }
            decimal = decimal / toBase;
        }
        return result;
    }
    
    // Check if number is valid for the base
    public static boolean isValid(String number, int base) {
        for (char c : number.toCharArray()) {
            if (Character.digit(c, base) == -1) {
                return false;
            }
        }
        return number.length() > 0;
    }

    // Get base number from user choice (1-4)
    public static int getBaseFromChoice(int choice) {
        if (choice == 1) return 2;
        else if (choice == 2) return 8;
        else if (choice == 3) return 10;
        else if (choice == 4) return 16;
        else return -1;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("=== Number System Converter ===");
        System.out.println("Choose source base: \n1=Binary \n2=Octal \n3=Decimal \n4=Hexadecimal");
        System.out.print("Enter choice (1-4): ");
        int sourceChoice = sc.nextInt();
        sc.nextLine();

        // Get source base
        int sourceBase = getBaseFromChoice(sourceChoice);
        if (sourceBase == -1) {
            System.out.println("Invalid choice!");
            sc.close();
            return;
        }

        // Get user number
        System.out.print("Enter your number: ");
        String number = sc.nextLine().trim().toUpperCase();

        if (!isValid(number, sourceBase)) {
            System.out.println("Invalid number for base " + sourceBase + "!");
            sc.close();
            return;
        }

        System.out.println("Choose target base: \n1=Binary \n2=Octal \n3=Decimal \n4=Hexadecimal");
        System.out.print("Enter choice (1-4): ");
        int targetChoice = sc.nextInt();

        // Get target base
        int targetBase = getBaseFromChoice(targetChoice);
        if (targetBase == -1) {
            System.out.println("Invalid choice!");
            sc.close();
            return;
        }

        // Convert and display result
        int decimalValue = toDecimal(number, sourceBase);
        String result = fromDecimal(decimalValue, targetBase);

        System.out.println("\n=== Result ===");
        System.out.println(number + " (Base " + sourceBase + ") = " + result + " (Base " + targetBase + ")");

        sc.close();
    }
}
